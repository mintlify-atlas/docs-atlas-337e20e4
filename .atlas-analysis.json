  "keyFeatures": [
    "License key generation and management",
    "Real-time license validation with Redis caching",
    "Machine-binding for single-device activation",
    "Automatic license expiration and revocation",
    "Multi-language SDK support (Node.js, Python, .NET)",
    "Background daemon for continuous validation",
    "Dashboard for client and project management",
    "OAuth integration for user authentication"
  ],
  "publicApiSurface": [
    "POST /validate - Validate license key",
    "POST /validate/activate - Activate license on machine",
    "POST /license/create - Create new license",
    "PATCH /license/revoke/:key - Revoke license",
    "activateLicense() - Node.js SDK",
    "startLicenseDaemon() - Node.js SDK",
    "protectNodeApp() - Node.js SDK",
    "activate_license() - Python SDK",
    "start_license_daemon() - Python SDK",
    "protect_fastapi_app() - Python SDK",
    "ActivateLicenseAsync() - .NET SDK",
    "StartLicenseDaemonAsync() - .NET SDK",
    "RunProtectedAsync() - .NET SDK"
